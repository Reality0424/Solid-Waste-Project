# 环境变量示例
# 复制此文件为 .env 并填入实际的值

# 数据路径
DATA_RAW_PATH=data/raw/
DATA_SYNTHETIC_PATH=data/synthetic/
DATA_PROCESSED_PATH=data/processed/

# 模型路径
MODELS_PATH=results/models/
FIGURES_PATH=results/figures/
REPORTS_PATH=results/reports/

# 日志
LOG_LEVEL=INFO
LOG_PATH=logs/

# 数据库（如果使用）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=chip_remanufacturing

# API配置
API_PORT=8000
API_HOST=0.0.0.0

# 其他
RANDOM_SEED=42
DEVICE=cuda  # 或 cpu
